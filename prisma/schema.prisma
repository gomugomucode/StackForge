generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  password           String?
  emailVerified      DateTime?
  avatar             String?
  plan               String              @default("FREE")
  stripeCustomerId   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  achievements       Achievement[]
  bookmarks          Bookmark[]
  certifications     Certification[]
  challengeProgress  ChallengeProgress[]
  memberships        CircleMembership[]
  dailyActivities    DailyActivity[]
  profile            Profile?
  progress           Progress[]
  submissions        ProjectSubmission[]
  quizAttempts       QuizAttempt[]
  reviews            Review[]
  roadmapCompletions RoadmapCompletion[]
  sessions           Session[]
  streakTrackings    StreakTracking?
  topicProgress      TopicProgress[]
  xpTransactions     XpTransaction[]
}

model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique
  xp         Int      @default(0)
  streak     Int      @default(0)
  level      Int      @default(1)
  totalHours Int      @default(0)
  lastActive DateTime @default(now())
  joinedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id           String    @id @default(cuid())
  userId       String
  lessonId     String
  completed    Boolean   @default(false)
  lastAccessed DateTime  @default(now())
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  type       String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Certification {
  id               String   @id @default(cuid())
  userId           String
  roadmapId        String
  issuedAt         DateTime @default(now())
  score            Int
  verificationCode String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
}

model Circle {
  id          String             @id @default(cuid())
  name        String
  description String?
  roadmapId   String?
  createdAt   DateTime           @default(now())
  members     CircleMembership[]
}

model CircleMembership {
  id       String   @id @default(cuid())
  userId   String
  circleId String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, circleId])
}

model ProjectSubmission {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  repoUrl     String
  demoUrl     String?
  description String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews     Review[]
}

model Review {
  id           String            @id @default(cuid())
  userId       String
  submissionId String
  rating       Int
  comment      String
  createdAt    DateTime          @default(now())
  submission   ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  quizId         String
  score          Int
  percentage     Int
  passed         Boolean  @default(false)
  correctAnswers Int
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Roadmap {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  category    String
  color       String
  icon        String
  overview    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  finalExam   FinalExam?
  modules     Module[]
}

model Module {
  id          String   @id @default(cuid())
  roadmapId   String
  slug        String
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String     @id @default(cuid())
  moduleId       String
  slug           String
  title          String
  description    String
  whatIsIt       String
  whyItMatters   String
  syntax         String
  declaration    String
  example        String
  commonMistakes String
  practiceTask   String
  quizId         String?
  cheatsheetId   String?
  interviewId    String?
  difficulty     String     @default("beginner")
  estimatedHours Int        @default(1)
  prerequisites  String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  module         Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources      Resource[]
}

model Resource {
  id       String @id @default(cuid())
  lessonId String
  title    String
  url      String
  type     String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model CheatSheet {
  id        String   @id @default(cuid())
  lessonId  String?
  topicId   String?
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model InterviewQuestion {
  id               String   @id @default(cuid())
  lessonId         String?
  topicId          String?
  question         String
  answer           String
  difficulty       String
  tags             String[]
  companyFrequency Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  topic            Topic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Project {
  id          String              @id @default(cuid())
  title       String
  description String
  difficulty  String
  roadmapId   String?
  topicId     String?
  resources   String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  topic       Topic?              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  submissions ProjectSubmission[]
}

model FinalExam {
  id           String     @id @default(cuid())
  roadmapId    String     @unique
  passingScore Int
  roadmap      Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  questions    Question[]
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?
  difficulty  String
  type        String     @default("full")
  lessonId    String?
  roadmapId   String?
  topicId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
  topic       Topic?     @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Question {
  id          String     @id @default(cuid())
  quizId      String?
  examId      String?
  question    String
  options     String[]
  answer      String
  explanation String?
  difficulty  String
  exam        FinalExam? @relation(fields: [examId], references: [id], onDelete: Cascade)
  quiz        Quiz?      @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Topic {
  id                 String              @id @default(cuid())
  slug               String              @unique
  technology         String
  title              String
  description        String
  difficulty         String
  estimatedTime      Int                 @default(60)
  prerequisites      String[]
  learningObjectives String[]
  tags               String[]
  nextTopics         String[]
  roadmapId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  challenges         Challenge[]
  cheatSheets        CheatSheet[]
  interviews         InterviewQuestion[]
  projects           Project[]
  quizzes            Quiz[]
  content            TopicContent?
  examples           TopicExample[]
  progress           TopicProgress[]
}

model TopicContent {
  id                  String   @id @default(cuid())
  topicId             String   @unique
  whatIsIt            String?
  whyItMatters        String?
  overview            String
  syntax              String
  explanation         String
  visualExplanation   String?
  beginnerExample     String?
  intermediateExample String?
  advancedExample     String?
  summary             String?
  bestPractices       String[]
  commonMistakes      String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  topic               Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model TopicExample {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  code        String
  output      String
  explanation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Challenge {
  id             String   @id @default(cuid())
  topicId        String
  title          String
  description    String
  difficulty     String
  solution       String
  hints          String[]
  expectedOutput String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model XpTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyActivity {
  id       String @id @default(cuid())
  userId   String
  date     String
  xpEarned Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model StreakTracking {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActive    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoadmapCompletion {
  id                   String   @id @default(cuid())
  userId               String
  roadmapId            String
  completionPercentage Int      @default(0)
  finalQuizScore       Int?
  challengeCompletion  Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
}

model TopicProgress {
  id           String    @id @default(cuid())
  userId       String
  topicId      String
  completed    Boolean   @default(false)
  lastAccessed DateTime  @default(now())
  completedAt  DateTime?
  topic        Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model ChallengeProgress {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  completed   Boolean  @default(false)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}
